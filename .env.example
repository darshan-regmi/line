# Copy this file to .env.local and fill in your own values.
# Vars prefixed with EXPO_PUBLIC_ are inlined at build time and shipped to the client.

# --- Firebase ---
# From: Firebase Console → Project settings → General → Your apps → Web app config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Optional — only set if you enabled Google Analytics for the Firebase project
EXPO_PUBLIC_MEASUREMENT_ID=

# --- Google Sign-In (via expo-auth-session) ---
# From: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create three OAuth clients (iOS, Android, Web) for the Firebase project.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
