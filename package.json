{
  "name": "line",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "check-typescript": "tsc --noEmit",
    "check-eslint": "eslint './src/**/*{js,ts,jsx,tsx}'",
    "lint": "npm run check-typescript && npm run check-eslint",
    "prettier": "prettier --plugin '@trivago/prettier-plugin-sort-imports' --log-level error --no-error-on-unmatched-pattern --write src/**/*.{js,ts,jsx,tsx}",
    "release": "standard-version",
    "prepare": "husky",
    "test": "jest",
    "backfill-search": "node scripts/backfill-search-fields.js"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint './src/**/*{js,ts,jsx,tsx}' --fix",
      "prettier --write './src/**/*{js,ts,jsx,tsx}'"
    ]
  },
  "keywords": [
    "react-native",
    "expo",
    "typescript",
    "template"
  ],
  "author": "Vladimir Vovk",
  "license": "MIT",
  "homepage": "https://github.com/vladimir-vovk/expo-ts",
  "bugs": {
    "url": "https://github.com/vladimir-vovk/expo-ts/issues"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "^56.0.0",
    "expo-auth-session": "~56.0.13",
    "expo-crypto": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-async-storage": "^0.0.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react-native": "^13.3.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-plugin-jest": "^29.2.1",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-testing-library": "^7.13.5",
    "firebase-admin": "^13.10.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "standard-version": "^9.5.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
