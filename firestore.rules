rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // ─── Users ───────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read profile docs (for feeds, author cards, etc.)
      allow read: if isAuthed();

      // First write must be self, and counters must start at zero
      allow create: if isSelf(userId)
        && request.resource.data.uid == userId
        && request.resource.data.followersCount == 0
        && request.resource.data.followingCount == 0;

      // Self can update anything on their own profile
      allow update: if isSelf(userId);

      // Any signed-in user can bump THIS user's followersCount by exactly ±1
      // (used when someone else follows/unfollows this user — see /followers/{...})
      allow update: if isAuthed()
        && changedKeys().hasOnly(['followersCount', 'updatedAt'])
        && (request.resource.data.followersCount == resource.data.followersCount + 1
            || request.resource.data.followersCount == resource.data.followersCount - 1);

      // Only self can delete their profile doc
      allow delete: if isSelf(userId);

      // Following subcollection — owned by the FOLLOWER
      // /users/{follower}/following/{target}
      match /following/{targetUid} {
        allow read: if isAuthed();
        allow create, delete: if isSelf(userId);
      }

      // Followers subcollection — owned by the TARGET, written by the follower
      // /users/{target}/followers/{follower}
      match /followers/{followerUid} {
        allow read: if isAuthed();
        allow create, delete: if isSelf(followerUid);
      }

      // Bookmarks subcollection — strictly private to the owner.
      // The doc id is the postId; the body holds createdAt.
      // /users/{uid}/bookmarks/{postId}
      match /bookmarks/{postId} {
        allow read, create, update, delete: if isSelf(userId);
      }

      // Blocked-users subcollection — strictly private to the blocker.
      // Doc id == the blocked user's uid; body holds blockedAt.
      // /users/{uid}/blocked/{blockedUid}
      match /blocked/{blockedUid} {
        allow read, create, update, delete: if isSelf(userId);
      }

      // Notifications subcollection — recipient-owned inbox.
      // Any signed-in user (the "actor") can drop a notification here, but
      // they can never read what's in someone else's inbox.
      // /users/{recipient}/notifications/{notifId}
      match /notifications/{notifId} {
        // Only the recipient can read their own inbox
        allow read: if isSelf(userId);

        // Recipient can mark a notification read (toggling the `read` flag),
        // but not modify any other field.
        allow update: if isSelf(userId)
          && changedKeys().hasOnly(['read']);

        // Recipient can delete their own notifications
        allow delete: if isSelf(userId);

        // Anyone authed can drop a notification, with strict constraints:
        // - actorUid must be the writer (no impersonation)
        // - recipientUid must match the path
        // - cannot self-notify
        // - read must start false
        // - type must be one of the three known kinds
        allow create: if isAuthed()
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.recipientUid == userId
          && request.resource.data.actorUid != request.resource.data.recipientUid
          && request.resource.data.read == false
          && request.resource.data.type in ['like', 'comment', 'follow'];
      }
    }

    // ─── Usernames ───────────────────────────────────────────────────
    // Lowercased username claims. Doc id is the lowercased username.
    // Existence of the doc means the username is taken. Body holds
    // { uid, claimedAt } so we can release the claim during account
    // deletion or username changes.
    match /usernames/{usernameLower} {
      // Anyone (including signed-out signup forms) can probe a single doc
      // to check availability. Usernames are public on profiles/posts already.
      allow get: if true;
      // List is intentionally closed — no one needs to enumerate claims
      allow list: if false;

      // Only the claiming user can create the doc, and uid must match
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid;

      // Claims are immutable; rename via delete + re-create
      allow update: if false;

      // Only the owner of a claim can release it
      allow delete: if isAuthed() && resource.data.uid == request.auth.uid;
    }

    // ─── Posts ───────────────────────────────────────────────────────
    match /posts/{postId} {
      // Posts are public to read (matches the social-feed model)
      allow read: if true;

      // Create: must be authored by the requester, counters start at zero
      allow create: if isAuthed()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.likes.size() == 0
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0;

      // Author can edit / delete their own post
      allow update: if isSelf(resource.data.userId);
      allow delete: if isSelf(resource.data.userId);

      // Anyone signed-in can toggle their OWN like
      // (modifies likes + likesCount + updatedAt only, and only by exactly one user)
      allow update: if isAuthed() && isOwnLikeToggle();

      // Anyone signed-in can bump commentsCount by exactly +1 when posting a comment
      allow update: if isAuthed()
        && changedKeys().hasOnly(['commentsCount', 'updatedAt'])
        && request.resource.data.commentsCount == resource.data.commentsCount + 1;

      // Anyone signed-in can bump viewCount by exactly +1 (opening PostDetail).
      // No dedup per viewer; trade-off documented in postService.incrementPostView.
      // Uses `.get` so older posts created before viewCount existed still bump cleanly.
      allow update: if isAuthed()
        && changedKeys().hasOnly(['viewCount'])
        && request.resource.data.viewCount == resource.data.get('viewCount', 0) + 1;

      // ─── Comments (subcollection) ──────────────────────────────────
      match /comments/{commentId} {
        // Anyone (even signed-out) can read comments — comments on public posts
        allow read: if true;

        allow create: if isAuthed()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.likes.size() == 0
          && request.resource.data.likesCount == 0;

        // Comment author can edit/delete their own comment
        allow update: if isSelf(resource.data.userId);
        allow delete: if isSelf(resource.data.userId);

        // Anyone authed can toggle their OWN like on the comment
        allow update: if isAuthed() && isOwnCommentLikeToggle();
      }
    }

    // ─── Like-toggle guard ───────────────────────────────────────────
    // Verifies an update only adds-or-removes exactly the requesting user's uid
    // from `likes`, and adjusts `likesCount` by exactly the matching ±1.
    function isOwnLikeToggle() {
      let uid = request.auth.uid;
      let cur = resource.data.likes;
      let next = request.resource.data.likes;
      let wasLiked = uid in cur;
      let nowLiked = uid in next;
      // The set of OTHER users' likes must be unchanged
      let curOthers = cur.toSet().difference([uid].toSet());
      let nextOthers = next.toSet().difference([uid].toSet());

      return changedKeys().hasOnly(['likes', 'likesCount', 'updatedAt'])
        && wasLiked != nowLiked
        && curOthers == nextOthers
        && next.size() == cur.size() + (nowLiked ? 1 : -1)
        && request.resource.data.likesCount == resource.data.likesCount + (nowLiked ? 1 : -1);
    }

    // Same shape as isOwnLikeToggle but for the comments subcollection:
    // comments have no `updatedAt`, so allowed keys are just likes + likesCount.
    function isOwnCommentLikeToggle() {
      let uid = request.auth.uid;
      let cur = resource.data.likes;
      let next = request.resource.data.likes;
      let wasLiked = uid in cur;
      let nowLiked = uid in next;
      let curOthers = cur.toSet().difference([uid].toSet());
      let nextOthers = next.toSet().difference([uid].toSet());

      return changedKeys().hasOnly(['likes', 'likesCount'])
        && wasLiked != nowLiked
        && curOthers == nextOthers
        && next.size() == cur.size() + (nowLiked ? 1 : -1)
        && request.resource.data.likesCount == resource.data.likesCount + (nowLiked ? 1 : -1);
    }

    // ─── DMs ─────────────────────────────────────────────────────────
    // /threads/{threadId} — 1:1 conversation envelope.
    // threadId convention: sortedUids.join('_'), so the same pair always
    // maps to the same id (client enforces; rules don't validate the
    // shape — they only check participant membership).
    match /threads/{threadId} {
      // GET allows reading a non-existent doc (so getOrCreateThread can
      // probe without a permission error), OR reading when the auth uid
      // is a participant. LIST is per-doc filtered by the same predicate
      // so where(participantIds array-contains uid) queries work.
      allow get: if resource == null
        || (isAuthed() && request.auth.uid in resource.data.participantIds);

      allow list: if isAuthed() && request.auth.uid in resource.data.participantIds;

      allow create: if isAuthed()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;

      // Updates allowed for participants. participantIds is immutable.
      allow update: if isAuthed()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.participantIds == resource.data.participantIds;

      // No client deletes — preserves history
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        function inThread() {
          return isAuthed()
            && request.auth.uid in
              get(/databases/$(database)/documents/threads/$(threadId)).data.participantIds;
        }

        allow read: if inThread();

        allow create: if inThread()
          && request.auth.uid == request.resource.data.senderId;

        // Messages are immutable from the client
        allow update, delete: if false;
      }
    }

    // ─── Reports ─────────────────────────────────────────────────────
    // Moderation queue. Any signed-in user can submit a report; nobody
    // can read, update, or delete from the client. Admins review reports
    // through the Firebase Console.
    match /reports/{reportId} {
      allow create: if isAuthed()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.targetType in ['post', 'comment', 'user']
        && request.resource.data.reason in
          ['spam', 'harassment', 'hate', 'sexual', 'self_harm', 'misinformation', 'other'];

      allow read, update, delete: if false;
    }

    // ─── Collections ─────────────────────────────────────────────────
    // Top-level collection docs. Each one belongs to a single owner (the
    // curator). Reads are public when isPublic == true; private collections
    // are only readable by their owner.
    match /collections/{collectionId} {
      allow read: if resource.data.isPublic == true || isSelf(resource.data.ownerId);

      allow create: if isAuthed()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.postCount == 0;

      allow update: if isSelf(resource.data.ownerId);
      allow delete: if isSelf(resource.data.ownerId);

      // Subcollection of post references inside a collection.
      // Body holds addedAt; doc id == postId so add/remove is O(1).
      match /posts/{postId} {
        // Inherit visibility from the parent collection
        allow read: if get(/databases/$(database)/documents/collections/$(collectionId)).data.isPublic == true
          || isSelf(get(/databases/$(database)/documents/collections/$(collectionId)).data.ownerId);

        // Only the owner can add or remove posts
        allow create, update, delete: if isSelf(
          get(/databases/$(database)/documents/collections/$(collectionId)).data.ownerId
        );
      }
    }
  }
}
